{
  "manifest_version": 3,
  "name": "FavGrove - Bookmark Manager",
  "version": "0.2.0",
  "description": "A local-first bookmark manager for Chrome and Edge.",
  "permissions": ["alarms", "bookmarks", "storage"],
  "optional_host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open FavGrove",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  }
}
