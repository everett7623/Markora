{
  "manifest_version": 3,
  "name": "Bookmark Management Master",
  "version": "0.1.0",
  "description": "Professional local-first bookmark management for Chrome and Edge.",
  "permissions": ["bookmarks", "storage", "tabs"],
  "optional_host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Bookmark Management Master"
  },
  "options_ui": {
    "page": "index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  }
}
